generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id
  username String @unique
  email    String @unique
  role     Role   @default(ADMIN)
}

model Member {
  id           String       @id
  memberNumber String       @unique // Church membership number
  username     String       @unique
  firstName    String
  lastName     String
  email        String?      @unique
  phone        String?      @unique
  address      String
  dateOfBirth  DateTime
  gender       Gender
  maritalStatus MaritalStatus @default(SINGLE)
  occupation   String?
  profileImg   String?
  
  // Membership details
  baptismDate      DateTime?
  baptismChurch    String?
  joinDate         DateTime    @default(now())
  membershipStatus Status      @default(ACTIVE)
  
  // Family and relationships
  familyId        String?
  family          Family?      @relation(fields: [familyId], references: [id])
  spouseId        String?      @unique
  spouse          Member?      @relation("Spouse", fields: [spouseId], references: [id])
  
  // Church roles and groups
  departmentId    Int?
  department      Department?  @relation(fields: [departmentId], references: [id])
  ministryIds     String[]     // Many-to-many with Ministry
  ministries      Ministry[]   @relation("MemberMinistries")
  
  // Children (if parent)
  children        FamilyMember[] @relation("Parent")
  
  // Contributions and activities
  contributions   Contribution[]
  attendance      Attendance[]
  skills          String[]     // List of skills/talents
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Family {
  id             String    @id @default(uuid())
  familyName     String
  address        String
  homePhone      String?
  
  // Family members
  headOfFamily   String?   // Member ID
  members        Member[]
  children       FamilyMember[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model FamilyMember {
  id         String   @id @default(uuid())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id])
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  parentId   String?
  parent     Member?  @relation("Parent", fields: [parentId], references: [id])
  relationship Relationship
  
  createdAt  DateTime @default(now())
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  leaderId    String?
  leader      Member?  @relation(fields: [leaderId], references: [id])
  
  members     Member[]
  events      Event[]
  createdAt   DateTime @default(now())
}

model Ministry {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  leaderId    String?
  leader      Member?  @relation(fields: [leaderId], references: [id])
  meetingSchedule String? // e.g., "Every Sunday 9AM"
  meetingLocation String?
  
  members     Member[] @relation("MemberMinistries")
  events      Event[]
  createdAt   DateTime @default(now())
}

model Contribution {
  id          String         @id @default(uuid())
  memberId    String
  member      Member         @relation(fields: [memberId], references: [id])
  type        ContributionType
  amount      Float
  currency    String         @default("USD")
  paymentMethod PaymentMethod
  description String?
  date        DateTime       @default(now())
  receiptNumber String?       @unique
  
  fundId      Int?
  fund        Fund?          @relation(fields: [fundId], references: [id])
  createdAt   DateTime       @default(now())
}

model Fund {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  targetAmount Float?
  currentAmount Float   @default(0)
  startDate   DateTime
  endDate     DateTime?
  status      Status   @default(ACTIVE)
  
  contributions Contribution[]
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Sunday Morning Service", "Wednesday Bible Study"
  dayOfWeek   DayOfWeek
  startTime   DateTime
  endTime     DateTime
  location    String
  
  attendance  Attendance[]
  events      Event[]
}

model Attendance {
  id          String   @id @default(uuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id])
  date        DateTime @default(now())
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  
  createdAt   DateTime @default(now())
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  eventType   EventType
  startDate   DateTime
  endDate     DateTime
  location    String
  organizerId String?
  organizer   Member?  @relation(fields: [organizerId], references: [id])
  
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  ministryId   Int?
  ministry     Ministry?   @relation(fields: [ministryId], references: [id])
  
  expectedAttendees Int?
  actualAttendees   Int?
  budget       Float?
  expenses     Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PrayerRequest {
  id          String   @id @default(uuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  title       String
  description String
  isPublic    Boolean  @default(false)
  status      PrayerStatus @default(PENDING)
  answeredDate DateTime?
  testimony   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  priority    Priority @default(NORMAL)
  createdBy   String
  createdByMember Member @relation(fields: [createdBy], references: [id])
  
  targetAudience Audience @default(EVERYONE)
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  ministryId   Int?
  ministry     Ministry?   @relation(fields: [ministryId], references: [id])
  
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
}

// Enums
enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PASTOR
  MINISTRY_LEADER
  DEPARTMENT_HEAD
  MEMBER
}

enum Status {
  ACTIVE
  INACTIVE
  TRANSFERRED
  DECEASED
}

enum Relationship {
  HEAD
  SPOUSE
  CHILD
  PARENT
  OTHER
}

enum ContributionType {
  TITHE
  OFFERING
  FIRST_FRUITS
  VOW
  DONATION
  MISSION
  BUILDING_FUND
  OTHER
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  MOBILE_MONEY
  CREDIT_CARD
  ONLINE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum EventType {
  SERVICE
  BIBLE_STUDY
  PRAYER_MEETING
  FELLOWSHIP
  CONFERENCE
  OUTREACH
  WEDDING
  FUNERAL
  BAPTISM
  OTHER
}

enum PrayerStatus {
  PENDING
  ANSWERED
  IN_PROGRESS
  DECLINED
}

enum Audience {
  EVERYONE
  MEMBERS_ONLY
  DEPARTMENT
  MINISTRY
  LEADERSHIP
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}
